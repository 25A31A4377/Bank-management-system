#include <stdio.h>
#include <string.h>

#define MAX 100

struct Account {
    int accNo;
    char name[50];
    float balance;
};

struct Account acc[MAX];
int count = 0;

void createAccount() {
    int i;

    if(count >= MAX) {
        printf("Maximum Account Limit Reached!\n");
        return;
    }

    printf("Enter Account Number: ");
    scanf("%d", &acc[count].accNo);

    // Check duplicate account number
    for(i = 0; i < count; i++) {
        if(acc[i].accNo == acc[count].accNo) {
            printf("Account Number Already Exists!\n");
            return;
        }
    }

    printf("Enter Name: ");
    scanf(" %[^\n]", acc[count].name);

    printf("Enter Initial Balance: ");
    scanf("%f", &acc[count].balance);

    if(acc[count].balance < 0) {
        printf("Balance Cannot Be Negative!\n");
        return;
    }

    count++;

    printf("Account Created Successfully!\n");
}

void displayAccounts() {
    int i;

    if(count == 0) {
        printf("No Accounts Found!\n");
        return;
    }

    printf("\n----- ACCOUNT DETAILS -----\n");

    for(i = 0; i < count; i++) {
        printf("Account Number : %d\n", acc[i].accNo);
        printf("Name           : %s\n", acc[i].name);
        printf("Balance        : %.2f\n\n", acc[i].balance);
    }
}

void deposit() {
    int no, i;
    float amount;

    printf("Enter Account Number: ");
    scanf("%d", &no);

    for(i = 0; i < count; i++) {

        if(acc[i].accNo == no) {

            printf("Enter Amount: ");
            scanf("%f", &amount);

            if(amount <= 0) {
                printf("Invalid Amount!\n");
                return;
            }

            acc[i].balance += amount;

            printf("Deposit Successful!\n");
            printf("Updated Balance: %.2f\n", acc[i].balance);

            return;
        }
    }

    printf("Account Not Found!\n");
}

void withdraw() {
    int no, i;
    float amount;

    printf("Enter Account Number: ");
    scanf("%d", &no);

    for(i = 0; i < count; i++) {

        if(acc[i].accNo == no) {

            printf("Enter Amount: ");
            scanf("%f", &amount);

            if(amount <= 0) {
                printf("Invalid Amount!\n");
                return;
            }

            if(amount > acc[i].balance) {

                printf("Insufficient Balance!\n");

            } else {

                acc[i].balance -= amount;

                printf("Withdrawal Successful!\n");
                printf("Remaining Balance: %.2f\n",
                       acc[i].balance);
            }

            return;
        }
    }

    printf("Account Not Found!\n");
}

void checkBalance() {

    int no, i;

    printf("Enter Account Number: ");
    scanf("%d", &no);

    for(i = 0; i < count; i++) {

        if(acc[i].accNo == no) {

            printf("Current Balance: %.2f\n",
                   acc[i].balance);

            return;
        }
    }

    printf("Account Not Found!\n");
}

int main() {

    int choice;

    do {

        printf("\n===== BANK MANAGEMENT SYSTEM =====\n");

        printf("1. Create Account\n");
        printf("2. Display Accounts\n");
        printf("3. Deposit\n");
        printf("4. Withdraw\n");
        printf("5. Check Balance\n");
        printf("6. Exit\n");

        printf("Enter Choice: ");

        scanf("%d", &choice);

        switch(choice) {

            case 1:
                createAccount();
                break;

            case 2:
                displayAccounts();
                break;

            case 3:
                deposit();
                break;

            case 4:
                withdraw();
                break;

            case 5:
                checkBalance();
                break;

            case 6:
                printf("Thank You!\n");
                break;

            default:
                printf("Invalid Choice!\n");
        }

    } while(choice != 6);

    return 0;
}
    return 0;
}
